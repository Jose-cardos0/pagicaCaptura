# Hostinger (Apache) — copiado para a raiz do site no `npm run build` (pasta public/)
# Ajuste ou comente o que não precisar.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Descomente se quiser forçar HTTPS (muitos planos já redirecionam no painel)
  # RewriteCond %{HTTPS} !=on
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # SPA: URLs que não são arquivo nem pasta → index.html (mantém /landingpage.html e /assets/* intactos)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Compressão (se o servidor tiver mod_deflate ativo)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache agressivo só para assets com hash do Vite (ajuste se mudar a pasta)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
